# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/agrilink

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# ── FastAPI price prediction service ─────────────────────────────────────────
FASTAPI_URL=https://agrilink-ml-3.onrender.com/predict-price

# ── ML crop quality prediction service ───────────────────────────────────────
ML_QUALITY_URL=https://agrilink-ml-7.onrender.com/analyze-image

# ── Public app URL (used in QR codes) ────────────────────────────────────────
APP_URL=http://localhost:5000

# ── CORS (comma-separated) ────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Matching weights (must sum to 1.0) ───────────────────────────────────────
MATCH_DISTANCE_W=0.4
MATCH_DEMAND_W=0.35
MATCH_PRICE_W=0.25
